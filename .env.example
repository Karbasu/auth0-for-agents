# Auth0 M2M App (client credentials)
AUTH0_DOMAIN=dev-robo.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://dev-robo.us.auth0.com/api/v2/

# Granted scopes (comma-separated) — controls which tools the AI can see
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
GITHUB_SCOPES=repo,read:user
CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly
