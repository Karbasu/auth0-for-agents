# Auth0 Regular Web App (client credentials for Management API)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# Auth0 User ID (set automatically by get-token.js)
AUTH0_USER_ID=google-oauth2|your-user-id

# Granted scopes (comma-separated) — controls which tools the AI can see
# Remove a scope to hide the corresponding tools (Authorization by Omission)
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.compose,https://www.googleapis.com/auth/gmail.send
GITHUB_SCOPES=repo,read:user
CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/calendar.events

# Refresh token (saved by get-token.js — not used by MCP server at runtime)
USER_REFRESH_TOKEN=
